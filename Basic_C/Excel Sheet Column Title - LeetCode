
char* convertToTitle(int columnNumber) {
    int i=0;
    char *st=malloc(100*sizeof(char));
    while(columnNumber>0)
    {
        columnNumber--;
        int r=columnNumber%26;
        st[i]='A'+r;
        columnNumber=columnNumber/26;
        i++;
    }
    for(int j=0;j<i/2;j++)
    {
        char t=st[j];
        st[j]=st[i-j-1];
        st[i-j-1]=t;
    }
    st[i]='\0';
    return st;
}
