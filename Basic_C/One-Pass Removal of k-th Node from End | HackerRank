SinglyLinkedListNode* removeKthNodeFromEnd(SinglyLinkedListNode* head, int k) {
    int l=0;
    SinglyLinkedListNode* temp=head;
    while(temp!=NULL)
    {
        temp=temp->next;
        l++;
    }
    if(k>=l|| head==NULL)
    {
        return head;
    }
    k=l-k;
    temp=head;
    if(k==1)
    {
       head=head->next;
       free(temp); 
       return head;
    }
    for(int i=1;i<k-1;i++)
    {
        temp=temp->next;
    }
    SinglyLinkedListNode *tempn=temp->next;
    temp->next=temp->next->next;
    free(tempn);
    return head;
    
    
}
