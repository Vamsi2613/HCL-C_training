char* longestCommonPrefix(char** strs, int strsSize) {
    if(strsSize==0)
    {
        return "";
    }
    int l;
    for(l=0;strs[0][l]!='\0';l++);
    for(int i=0;i<l;i++)
    {
        char ch=strs[0][i];
        for(int j=1;j<strsSize;j++)
        {
            if(ch!=strs[j][i])
            {
                strs[0][i]='\0';
                return strs[0];
            }
        }
    }
    return strs[0];
}
